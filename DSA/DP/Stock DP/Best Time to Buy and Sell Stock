class Solution {
    public int maxProfit(int[] prices) {
        int minCost = prices[0], profit = 0;
        for(int i=1; i<prices.length; i++){
            int price = prices[i] - minCost;
            profit = Math.max(profit, price);
            minCost = Math.min(minCost, prices[i]);
        }
        return profit;
    }
}
