class Solution {
    // node states
    // 0 -> node is not in monitor of camera (not covered) 
    // 1 -> camera needed (placed)
    // 2 -> covered by child's camera (covered)
    int camera=0;
    public int helper(TreeNode root){
        if(root == null) return 2;  
        int left=helper(root.left);
        int right=helper(root.right);
        if(left == 0 || right == 0){
            camera++;
            return 1;
        }
        if(left == 1 || right == 1) return 2;
        return 0;
    }
    public int minCameraCover(TreeNode root) {
        int root_state = helper(root);
        if(root_state == 0){
            camera++;
        }
        return camera;
    }
}
