class Solution {
    int count=0;
    public void helper(TreeNode root, long target){
        if(root == null) return;
        if(root.val == target) count++;
        helper(root.left, target-root.val);
        helper(root.right, target-root.val);
    } 
    public int pathSum(TreeNode root, int targetSum) {
        if(root == null) return 0;
        helper(root,targetSum);
        pathSum(root.left,targetSum);
        pathSum(root.right,targetSum);
        return count;
    } 
}  

// Optimised in O(N) -> Using prefix Sum
class Solution {
    public int helper(TreeNode root, long currSum, int targetSum, HashMap<Long, Integer> map){
        if(root == null) return 0;
        currSum += root.val;
        int count = map.getOrDefault(currSum - targetSum, 0);
        map.put(currSum, map.getOrDefault(currSum, 0) + 1);
        count += helper(root.left, currSum, targetSum, map);
        count += helper(root.right, currSum, targetSum, map);

        map.put(currSum, map.get(currSum) - 1);
        return count;
    }

    public int pathSum(TreeNode root, int targetSum) {
        HashMap<Long, Integer> map = new HashMap<>();
        map.put(0L, 1);
        return helper(root, 0, targetSum, map);
    }
}
